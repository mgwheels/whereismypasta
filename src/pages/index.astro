---
import BaseLayout from '../layouts/BaseLayout.astro';
import FeaturedVideo from '../components/FeaturedVideo';
import VideoGrid from '../components/VideoGrid';
---

<BaseLayout title="Airbourne Lens">
  <section class="hero">
    <h1 class="hero-title">Exploring the world from above.</h1>
    <p class="hero-subtitle">
      Cinematic 4K aerial footage from Scotland, the Maldives, Costa Rica, and beyond.
      Captured with DJI drones by a hobbyist with a passion for flight.
    </p>
    <a
      class="subscribe-btn"
      href="https://youtube.com/@AirbourneLens"
      target="_blank"
      rel="noopener noreferrer"
    >
      <svg class="btn-icon" viewBox="0 0 24 24" fill="currentColor">
        <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z" />
      </svg>
      Subscribe on YouTube
    </a>
  </section>

  <FeaturedVideo client:load />
  <VideoGrid client:load />
</BaseLayout>

<style>
  .hero {
    text-align: center;
    padding: 2rem 0 1.5rem;
  }

  .hero-title {
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .hero-subtitle {
    color: #64748b;
    max-width: 36rem;
    margin: 0 auto 1.25rem;
    line-height: 1.6;
    font-size: 0.95rem;
  }

  .subscribe-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.65rem 1.5rem;
    background-color: #ef4444;
    color: #fff;
    font-weight: 600;
    font-size: 0.875rem;
    border-radius: 9999px;
    text-decoration: none;
    transition: background-color 0.15s;
  }

  .subscribe-btn:hover {
    background-color: #dc2626;
  }

  .btn-icon {
    width: 1.25rem;
    height: 1.25rem;
  }
</style>

