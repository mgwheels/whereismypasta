---
import '../styles/global.css';
import Header from '../components/Header';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="page">
    <Header client:load />

    <main class="main-content">
      <slot />
    </main>

    <footer class="footer">
      &copy; {new Date().getFullYear()} Airbourne Lens. All rights reserved.
    </footer>
  </body>
</html>

<style>
  .page {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    overflow-x: hidden;
  }

  .main-content {
    flex: 1;
    max-width: 1152px;
    margin: 0 auto;
    padding: 0 1rem;
    width: 100%;
  }

  .footer {
    padding: 1.5rem 0;
    border-top: 1px solid #2a2829;
    text-align: center;
    font-size: 0.875rem;
    color: #6b686b;
  }
</style>
